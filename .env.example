#############################################
# Tienda Online — plantilla de variables de entorno
# Copia este archivo a `.env` y rellena los valores.
#   cp .env.example .env
#############################################

# ---------- Payload ----------
# Cadena aleatoria larga. Genera una con:  openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Necesario para que la CLI encuentre el config bajo /src (generate:types, migrate)
PAYLOAD_CONFIG_PATH=src/payload.config.ts

# ---------- Base de datos (Postgres) ----------
# PRODUCCIÓN (Supabase): usa el SESSION pooler (IPv4, soporta prepared statements).
#   Usuario = postgres.<project-ref> (NO 'postgres' a secas). URL-encodea la contraseña.
#   Supabase Dashboard > Connect > Session pooler
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
#
# DESARROLLO LOCAL (Docker, ver docker-compose.yml):
#   DATABASE_URL=postgres://store:store@127.0.0.1:5433/store
#
# (Solo serverless/Vercel) conexión de migraciones — SESSION pooler o directa, NUNCA :6543
#DATABASE_URL_DIRECT=postgres://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
#
# (Producción, opcional) CA de Supabase en PEM para verificación TLS COMPLETA (evita MITM).
# Sin esto, la conexión remota va cifrada pero sin verificar el certificado.
#DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# ---------- Supabase Auth / API (clientes del storefront) ----------
# Cliente (navegador) — SOLO estas se exponen al browser:
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Servidor (NUNCA con prefijo NEXT_PUBLIC_):
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# ---------- URL pública (CORS, links, sitemap). Sin barra final ----------
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---------- Preview / Cron ----------
PREVIEW_SECRET=YOUR_SECRET_HERE
CRON_SECRET=YOUR_CRON_SECRET_HERE

# ---------- Supabase Storage (S3-compatible) ----------
# Déjalas vacías para usar disco local en desarrollo.
# Rellénalas (Dashboard > Storage > S3 Connection > Access keys) para activar Supabase Storage.
# Crea DOS buckets: 'media' (público) y 'downloads' (privado).
#S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
#S3_REGION=eu-central-1
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_MEDIA_BUCKET=media
#S3_DOWNLOADS_BUCKET=downloads

# ---------- PayPal (Fase checkout — empieza por sandbox) ----------
# El SECRET y el WEBHOOK_ID son SOLO de servidor (nunca con prefijo NEXT_PUBLIC_).
#PAYPAL_ENVIRONMENT=sandbox
#PAYPAL_CLIENT_ID=
#PAYPAL_CLIENT_SECRET=
#PAYPAL_WEBHOOK_ID=
#NEXT_PUBLIC_PAYPAL_CLIENT_ID=
