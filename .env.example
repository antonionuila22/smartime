#############################################
# smartime — storefront (Next.js 16 + Medusa v2)
# Copia este archivo a `.env` y rellena los valores.
#   cp .env.example .env
#
# Solo variables NEXT_PUBLIC_* (este front no habla con la BD; todo va por el
# Store API de Medusa). Los secretos viven en el backend (../medusa/.env).
#############################################

# ---------- Backend Medusa (Store API) ----------
# URL del backend Medusa. Local: http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key de Medusa (Admin > Settings > Publishable API keys).
# DEBE estar vinculada al Sales Channel del catálogo o los listados saldrán vacíos.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx

# ---------- URL pública del storefront (CORS, links, sitemap). Sin barra final ----------
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---------- WhatsApp flotante (formato internacional sin +, ej. 504XXXXXXXX) ----------
NEXT_PUBLIC_WHATSAPP_NUMBER=504XXXXXXXX

# ---------- PayPal (checkout) ----------
# Solo el CLIENT ID es publico (lo usan los botones de PayPal en el navegador).
# El SECRET vive SOLO en el backend (../medusa/.env), nunca aqui.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# sandbox (default) | live  — debe coincidir con PAYPAL_ENVIRONMENT del backend.
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=sandbox

# ---------- Invalidación de caché en tiempo real (server-side, NO público) ----------
# Secreto que protege /api/revalidate. El backend Medusa lo envía en cada cambio de catálogo
# para refrescar la caché al instante. DEBE ser idéntico al REVALIDATE_SECRET del backend.
# Genera uno fuerte, p. ej.:  openssl rand -hex 32
REVALIDATE_SECRET=
